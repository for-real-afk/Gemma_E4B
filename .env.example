# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ── Required ──────────────────────────────────────────────────────────────────
# URL of your Ollama server (no trailing slash)
OLLAMA_HOST=http://localhost:11434

# Model name as registered in Ollama  (e.g. gemma3:4b  or  gemma4:e4b)
OLLAMA_MODEL=gemma3:4b

# API key if your Ollama endpoint requires one; leave empty if not needed
OLLAMA_API_KEY=

# Comma-separated list of frontend origins allowed by CORS
# Local dev:   http://localhost:5173
# Production:  https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use local SQLite (gemma_chat.db) — fine for development.
# Set to your Supabase connection string for persistent production storage.
# Get it from: Supabase dashboard → Project Settings → Database → URI
# Example: postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Optional ──────────────────────────────────────────────────────────────────
# Server port (Render sets $PORT automatically; keep 8000 for local dev)
PORT=8000

# INR exchange rate used for cost display
USD_TO_INR=85.0

# Session cache backend: "in_memory" (default) or "redis"
CACHE_TYPE=in_memory
REDIS_URL=redis://localhost:6379/0
